COMPOSE_MENU=false
COMPOSE_PROGRESS=plain
# COMPOSE_PROFILES=observability

VAR_PROJECT_POSTGRES_DB=var_risk_desk
VAR_PROJECT_POSTGRES_USER=var_user
VAR_PROJECT_POSTGRES_PASSWORD=var_password
VAR_PROJECT_API_URL=http://api:8000
VAR_PROJECT_NGINX_PORT=8081
VAR_PROJECT_API_WORKERS=1
VAR_PROJECT_API_MEM_LIMIT=1400m
VAR_PROJECT_API_LIVE_READ_WORKERS=2
VAR_PROJECT_API_LIVE_READ_TIMEOUT_MS=900
VAR_PROJECT_WORKER_MEM_LIMIT=1280m
VAR_PROJECT_DB_POOL_SIZE=4
VAR_PROJECT_DB_MAX_OVERFLOW=2
VAR_PROJECT_DB_POOL_TIMEOUT_SECONDS=10
VAR_PROJECT_DB_POOL_RECYCLE_SECONDS=180
VAR_PROJECT_MT5_LOGIN=
VAR_PROJECT_MT5_PASSWORD=
VAR_PROJECT_MT5_SERVER=
VAR_PROJECT_MT5_PATH=
VAR_PROJECT_MT5_TIMEOUT_MS=10000
VAR_PROJECT_MT5_LIVE_POLL_SECONDS=2.0
VAR_PROJECT_MT5_LIVE_HISTORY_POLL_SECONDS=30.0
VAR_PROJECT_MT5_AGENT_BASE_URL=http://host.docker.internal:8010
VAR_PROJECT_MT5_AGENT_API_KEY=
VAR_PROJECT_MT5_EXECUTION_ENABLED=true
VAR_PROJECT_MT5_MAGIC=420001
VAR_PROJECT_MT5_DEVIATION_POINTS=20
VAR_PROJECT_MT5_COMMENT_PREFIX=var_risk_desk
VAR_PROJECT_MT5_PORTABLE=true
VAR_PROJECT_OPERATOR_QUEUE_MODE=celery
VAR_PROJECT_CELERY_BROKER_URL=redis://redis:6379/0
VAR_PROJECT_CELERY_RESULT_BACKEND=redis://redis:6379/1
VAR_PROJECT_CELERY_QUEUE=operator_runs
VAR_PROJECT_CELERY_WORKER_CONCURRENCY=1
VAR_PROJECT_OPERATOR_SOFT_TIMEOUT_DEFAULT=120
VAR_PROJECT_OPERATOR_HARD_TIMEOUT_DEFAULT=180
VAR_PROJECT_OPERATOR_STALE_RUNNING_BACKTEST=420
VAR_PROJECT_OPERATOR_STALE_RUNNING_REPORT=360
VAR_PROJECT_OPERATOR_STALE_RUNNING_SNAPSHOT=240
VAR_PROJECT_OPERATOR_STALE_RUNNING_SYNC=120
VAR_PROJECT_OPERATOR_CACHE_TTL_BACKTEST=90
VAR_PROJECT_OPERATOR_CACHE_TTL_REPORT=120
VAR_PROJECT_OPERATOR_CACHE_TTL_SNAPSHOT=45
VAR_PROJECT_WORKER_LOOP_SLEEP_SECONDS=10
VAR_PROJECT_WORKER_SNAPSHOT_INTERVAL_SECONDS=180
VAR_PROJECT_WORKER_BACKTEST_INTERVAL_SECONDS=3600
VAR_PROJECT_WORKER_LIVE_REFRESH_INTERVAL_SECONDS=30
VAR_PROJECT_WORKER_REPORT_INTERVAL_SECONDS=3600
NEXT_PUBLIC_MT5_STREAM_MODE=auto
NEXT_PUBLIC_MT5_POLL_INTERVAL_MS=1200
NEXT_PUBLIC_MT5_MAX_POLL_INTERVAL_MS=2500
NEXT_PUBLIC_QUERY_STALE_MS=2000
NEXT_PUBLIC_DESK_ARTIFACT_QUERY_STALE_MS=2500
NEXT_PUBLIC_DESK_ARTIFACT_QUERY_REFETCH_MS=2500
NEXT_PUBLIC_DESK_ARTIFACT_INVALIDATE_MIN_MS=2000
VAR_PROJECT_LOG_LEVEL=INFO
