# Backend API URL (used server-side and in Docker)
VAR_PROJECT_API_BASE_URL=http://127.0.0.1:8000

# Internal Next.js base URL for PDF generation (server-side Playwright fetch)
NEXT_INTERNAL_BASE_URL=http://127.0.0.1:3000

# Path to Chromium executable for PDF generation (auto-detected if not set)
CHROMIUM_PATH=/usr/bin/chromium
